rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidServicePiece(piece) {
      return piece is map &&
             piece.id is string && piece.id.size() <= 128 &&
             piece.label is string && piece.label.size() <= 100 &&
             piece.selected is bool &&
             (piece.get('description', '') is string && piece.get('description', '').size() <= 2000) &&
             (piece.get('audioBlob', '') is string && piece.get('audioBlob', '').size() <= 2000000);
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'userId', 'customerName', 'vehicleNameColor', 'plate', 'cpfCnpj', 'whatsapp', 'pieces', 'includePartsValue', 'partsValue', 'includeLaborValue', 'laborValue', 'includeMaterialsValue', 'materialsValue', 'totalValue', 'observations', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 18 &&
             data.id is string && data.id.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.customerName is string && data.customerName.size() <= 200 &&
             data.vehicleNameColor is string && data.vehicleNameColor.size() <= 200 &&
             data.plate is string && data.plate.size() <= 20 &&
             data.cpfCnpj is string && data.cpfCnpj.size() <= 30 &&
             data.whatsapp is string && data.whatsapp.size() <= 30 &&
             data.pieces is list && data.pieces.size() <= 50 &&
             (data.pieces.size() == 0 || isValidServicePiece(data.pieces[0])) &&
             data.includePartsValue is bool &&
             data.partsValue is number &&
             data.includeLaborValue is bool &&
             data.laborValue is number &&
             data.includeMaterialsValue is bool &&
             data.materialsValue is number &&
             data.totalValue is number &&
             data.observations is string && data.observations.size() <= 5000 &&
             data.createdAt is string && 
             data.updatedAt is string;
    }

    match /notes/{noteId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(noteId) && 
                      isValidNote(incoming()) && 
                      incoming().id == noteId;
                      
      allow update: if isOwner(existing().userId) && 
                      isValidNote(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().id == existing().id &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['customerName', 'vehicleNameColor', 'plate', 'cpfCnpj', 'whatsapp', 'pieces', 'includePartsValue', 'partsValue', 'includeLaborValue', 'laborValue', 'includeMaterialsValue', 'materialsValue', 'totalValue', 'observations', 'updatedAt']);
                      
      allow delete: if isOwner(existing().userId);
    }
  }
}
